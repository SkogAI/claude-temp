    "ask": [],
    "deny": [],
    "additionalDirectories": [
      "/home/skogix/claude/"
    ]
  },
  "sandbox": {
    "enabled": false,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [],
    "allowUnsandboxedCommands": true,
    "enableWeakerNestedSandbox": false,
    "filesystem": {
      "allowWrite": [],
      "denyWrite": [],
      "denyRead": []
    },
    "network": {
      "allowedDomains": [],
      "allowUnixSockets": [],
      "allowAllUnixSockets": false,
      "allowLocalBinding": false
    }
  },
  "hooks": {},
  "extraKnownMarketplaces": {
    "skogai-marketplace": {
      "source": {
        "source": "directory",
        "path": "/home/skogix/.local/src/marketplace"
      }
    }
  },
}
