 subcommands\n# @arg args~ podman container arguments\ncontainer() {\n  podman container \"${argc_args[@]}\"\n}\n\n# @cmd SearXNG operations\n# @arg arg podman container arguments\nmain() {\n  echo \"$argc_arg\"\n}\n\n# @cmd SearXNG operations\nsearxng() {\n  :\n}\n\n# @cmd Start SearXNG\nsearxng::up() {\n  local dir=\"$CONTAINERS_DIR/searxng\"\n  if podman container exists searxng 2>/dev/null; then\n    echo \"searxng already exists, starting...\"\n    podman start searxng\n  else\n    podman run --name searxng -d \\\n      -p 8888:8080 \\\n      -v \"$dir/config/:/etc/searxng/:Z\" \\\n      -v \"$dir/data/:/var/cache/searxng/:Z\" \\\n      docker.io/searxng/searxng:latest\n  fi\n  echo \"SearXNG: http://localhost:8888\"\n}\n\n# @cmd Stop SearXNG\nsearxng::down() {\n  podman stop searxng\n}\n\n# @cmd Show SearXNG logs\n# @flag -f --follow Follow log output\nsearxng::logs() {\n  if [[ \"$argc_follow\" == \"1\" ]]; then\n    podman logs -f searxng\n  else\n    podman logs searxng\n  fi\n}\n\n# @cmd Open a shell in the SearXNG container\nsearxng::shell() {\n  podman exec -it --user root searxng /bin/sh -l\n}\n\n# @cmd Start all services\nup() {\n  argc searxng::up\n}\n\n# @cmd Stop all services\ndown() {\n  argc searxng::down\n}\n\n# @cmd List all containers\nlist() {\n  podman ps -a\n}\n\n# See more details at https://github.com/sigoden/argc\neval \"$(argc --argc-eval \"$0\" \"$@\")\"\n"},"sourceToolAssistantUUID":"dd2d8589-2619-4562-9e8b-4c93da73e4fc"}
