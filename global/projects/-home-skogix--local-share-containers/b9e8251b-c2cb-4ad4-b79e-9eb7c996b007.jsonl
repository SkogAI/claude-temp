rvices\nup() {\n    argc searxng::up\n}\n\n# @cmd Stop all services\ndown() {\n    argc searxng::down\n}\n\n# @cmd List all containers\nlist() {\n    podman ps -a\n}\n\n# See more details at https://github.com/sigoden/argc\neval \"$(argc --argc-eval \"$0\" \"$@\")\"\n","structuredPatch":[{"oldStart":39,"oldLines":7,"newStart":39,"newLines":7,"lines":[" # @cmd Show SearXNG logs"," # @flag -f --follow Follow log output"," searxng::logs() {","-    if [[ -n \"$argc_follow\" ]]; then","+    if [[ \"$argc_follow\" == \"1\" ]]; then","         podman logs -f searxng","     else","         podman logs searxng"]}],"userModified":false,"replaceAll":false},"sourceToolAssistantUUID":"bf156350-f7d3-4cd8-b508-664047b1fe15"}
